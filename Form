            };
        }

        public void UpdateCounter(int counter)
        {
            if (this.InvokeRequired) { this.Invoke(new Action(() => UpdateCounter(counter))); return; }
            lblCounter.Text = counter.ToString();
            if (counter < 30) lblCounter.BackColor = Color.FromArgb(220, 240, 220);
            else if (counter < 70) lblCounter.BackColor = Color.FromArgb(250, 250, 210);
            else lblCounter.BackColor = Color.FromArgb(255, 220, 220);
        }

        public void UpdateState(WorkerState state)
        {
            if (this.InvokeRequired) { this.Invoke(new Action(() => UpdateState(state))); return; }
            switch (state)
            {
                case WorkerState.Running:
                    lblState.Text = "Выполняется";
                    lblState.ForeColor = Color.Green;
                    btnPause.Enabled = true; btnResume.Enabled = false; btnStop.Enabled = true; btnClone.Enabled = true;
                    break;
                case WorkerState.Paused:
                    lblState.Text = "Приостановлен";
                    lblState.ForeColor = Color.Orange;
                    btnPause.Enabled = false; btnResume.Enabled = true; btnStop.Enabled = true; btnClone.Enabled = true;
                    break;
                case WorkerState.Stopping:
                    lblState.Text = "Остановка...";
                    lblState.ForeColor = Color.Red;
                    btnPause.Enabled = false; btnResume.Enabled = false; btnStop.Enabled = false; btnClone.Enabled = false;
                    break;
                case WorkerState.Stopped:
                    lblState.Text = "Остановлен";
                    lblState.ForeColor = Color.Gray;
                    btnPause.Enabled = false; btnResume.Enabled = false; btnStop.Enabled = false; btnClone.Enabled = false;
                    break;
            }
        }

        public void UpdatePriority(ThreadPriority priority)
        {
            if (this.InvokeRequired) { this.Invoke(new Action(() => UpdatePriority(priority))); return; }
            if (!isPriorityUpdating)
            {
                isUpdating = true;
                cbPriority.SelectedIndex = (int)priority;
                isUpdating = false;
            }
        }

        private void SyncPriority()
        {
            if (this.InvokeRequired) { this.Invoke(new Action(SyncPriority)); return; }
            try
            {
                var wi = manager.GetWorkerInfo(info.Id);
                if (wi != null && wi.IsAlive)
                {
                    int cur = (int)wi.Priority;
                    if (cbPriority.SelectedIndex != cur && !isPriorityUpdating)
                    {
                        isUpdating = true;
                        cbPriority.SelectedIndex = cur;
                        isUpdating = false;
                    }
                }
            }
            catch { }
        }

        private void DisableControls()
        {
            if (this.InvokeRequired) { this.Invoke(new Action(DisableControls)); return; }
            cbPriority.Enabled = false;
            btnPause.Enabled = false;
            btnStop.Enabled = false;
            btnResume.Enabled = false;
            btnClone.Enabled = false;
        }

        protected override void Dispose(bool disposing)
        {
            isDisposing = true;
            if (disposing) syncTimer?.Dispose();
            base.Dispose(disposing);
        }
    }

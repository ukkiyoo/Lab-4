    // Potoki
    public class WorkerControl : UserControl
    {
        private readonly WorkerInfo info;
        private readonly WorkerManager manager;
        private Label lblTitle;
        private Label lblCounter;
        private Label lblState;
        private ComboBox cbPriority;
        private Button btnPause;
        private Button btnStop;
        private Button btnResume;
        private Button btnClone;
        private TextBox txtNumber;
        private System.Windows.Forms.Timer syncTimer;
        private bool isUpdating = false;
        private bool isDisposing = false;
        private bool isPriorityUpdating = false;

        public int WorkerId => info.Id;

        public WorkerControl(WorkerInfo workerInfo, WorkerManager workerManager)
        {
            info = workerInfo;
            manager = workerManager;
            InitializeComponent();
            UpdateState(info.State);
            UpdateCounter(info.CurrentCounter);

            cbPriority.SelectedIndexChanged += (s, e) =>
            {
                if (isUpdating || isPriorityUpdating) return;
                if (manager.IsWorkerAlive(info.Id) && cbPriority.SelectedIndex >= 0)
                {
                    isPriorityUpdating = true;
                    manager.SetWorkerPriority(info.Id, (ThreadPriority)cbPriority.SelectedIndex);
                    isPriorityUpdating = false;
                }
            };

            syncTimer = new System.Windows.Forms.Timer { Interval = 1000 };
            syncTimer.Tick += (s, e) =>
            {
                if (isDisposing) return;
                try
                {
                    if (this.IsHandleCreated && manager.IsWorkerAlive(info.Id))
                    {
                        if (!isPriorityUpdating) SyncPriority();
                    }
                    else if (!manager.IsWorkerAlive(info.Id))
                    {
                        DisableControls();
                        syncTimer.Stop();
                    }
                }
                catch (ObjectDisposedException) { syncTimer.Stop(); }
            };
            syncTimer.Start();
        }


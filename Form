        private void OnDataExchange(int id, DataMessage msg)
        {
            this.Invoke(new Action(() =>
            {
                string dir = msg.DataType == "Ответ" ? "Дочерний → Родитель" : "Родитель → Дочерний";
                string displayType = msg.DataType == "Число" ? "Число" :
                                    msg.DataType == "Команда" ? "Команда" : "Ответ";
                dgvDataExchange.Rows.Insert(0,
                    DateTime.Now.ToString("HH:mm:ss"),
                    id,
                    dir,
                    displayType,
                    msg.Content);
                while (dgvDataExchange.Rows.Count > 100) dgvDataExchange.Rows.RemoveAt(dgvDataExchange.Rows.Count - 1);
            }));
        }

        private void UiTimer_Tick(object sender, EventArgs e)
        {
            workerManager.CleanupDeadWorkers();
            var existing = flowPanel.Controls.Cast<WorkerControl>().ToList();
            var current = workerManager.GetAllWorkers();

            foreach (var ctrl in existing)
                if (!current.Any(w => w.Id == ctrl.WorkerId))
                {
                    flowPanel.Controls.Remove(ctrl);
                    ctrl.Dispose();
                }

            foreach (var info in current)
                if (!existing.Any(c => c.WorkerId == info.Id))
                {
                    var ctrl = new WorkerControl(info, workerManager);
                    flowPanel.Controls.Add(ctrl);
                }

            int totalHeight = flowPanel.Controls.Count * 105;
            flowPanel.Height = totalHeight;
            ((Panel)flowPanel.Parent).AutoScrollMinSize = new Size(0, totalHeight + 24);
        }

        private WorkerControl FindWorkerControl(int id)
        {
            foreach (WorkerControl ctrl in flowPanel.Controls)
                if (ctrl.WorkerId == id) return ctrl;
            return null;
        }

